# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pesas_app"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl"
# For backward compatibility (NextAuth v5 uses AUTH_SECRET)
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"

# NextAuth URL Configuration (Required for production)
# Set this to your production domain
NEXTAUTH_URL="http://localhost:3000"
# For NextAuth v5
AUTH_URL="http://localhost:3000"

# Optional: Trust host in production (already set in code)
AUTH_TRUST_HOST="true"

# Node Environment
NODE_ENV="development"
